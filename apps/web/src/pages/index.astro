---
import Layout from '../layouts/Layout.astro';

const token = Astro.cookies.get('token')?.value;
const isLoggedIn = !!token;

const API_URL = process.env.API_URL || 'http://api:3000';

let balanceSats: string | null = null;
let balanceBtc: string | null = null;

if (isLoggedIn && token) {
  try {
    const res = await fetch(`${API_URL}/api/deposits/balance`, {
      headers: {
        Authorization: `Bearer ${token}`,
      },
    });
    if (res.ok) {
      const data = (await res.json()) as { balanceSats: string };
      balanceSats = data.balanceSats;
      balanceBtc = (Number(data.balanceSats) / 1e8).toFixed(8);
    }
  } catch {
    // Balance fetch is best-effort; don't break the page
  }
}
---

<Layout title="Crypto Demo">
  <div class="min-h-screen flex flex-col items-center justify-center p-4">
    <div class="card w-full max-w-md bg-base-100 shadow-xl">
      <div class="card-body gap-4">
        <h1 class="card-title text-2xl">Crypto Demo</h1>

        {isLoggedIn ? (
          <>
            <p class="text-success font-medium">Logged in</p>

            {balanceSats !== null && (
              <div class="stats shadow w-full">
                <div class="stat">
                  <div class="stat-title">Balance</div>
                  <div class="stat-value text-primary text-xl">{balanceBtc} BTC</div>
                  <div class="stat-desc">{Number(balanceSats).toLocaleString()} sats</div>
                </div>
              </div>
            )}

            <div class="card-actions flex-wrap gap-2">
              <a href="/deposit" class="btn btn-primary">Deposit BTC</a>
              <a href="/logout" class="btn btn-outline btn-sm">Log out</a>
            </div>
          </>
        ) : (
          <div class="card-actions">
            <a href="/login" class="btn btn-primary">Log in</a>
            <a href="/signup" class="btn btn-outline">Sign up</a>
          </div>
        )}

        <div class="divider"></div>

        <button id="hello-btn" class="btn btn-secondary">Test API Connection</button>
        <p id="result" class="text-sm"></p>
      </div>
    </div>
  </div>

  <script>
    const apiBase = import.meta.env.PUBLIC_API_URL || '';
    document.getElementById('hello-btn')?.addEventListener('click', async () => {
      const result = document.getElementById('result')!;
      result.className = 'text-sm';
      result.textContent = 'Loading...';
      try {
        const res = await fetch(`${apiBase}/api/hello`);
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        result.textContent = await res.text();
      } catch (e) {
        result.classList.add('text-error');
        result.textContent = `Error: ${e instanceof Error ? e.message : 'Could not reach API'}`;
      }
    });
  </script>
</Layout>
